DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/study_app
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-q3_K_M
OLLAMA_API_KEY=your_ollama_cloud_api_key
# Input context window. Ollama silently truncates prompts longer than this,
# which drops the JSON-schema instruction and makes generation return 0 questions.
OLLAMA_NUM_CTX=8192
GROQ_API_KEY=api_key_for_groq
GOOGLE_AI_API_KEY=your_google_ai_api_key
# Model used for every Gemini call (JSON generation, Kojo chat, streaming).
GOOGLE_AI_MODEL=gemini-2.0-flash
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
MAX_FILE_SIZE_BYTES=52428800
ALLOWED_FILE_TYPES=pdf,txt
LLM_MAX_TOKENS=1000
LLM_TIMEOUT_SECONDS=60
LLM_GENERATION_TIMEOUT_SECONDS=180
LLM_UNCERTAINTY_THRESHOLD=0.6
# Comma-separated list of admin emails (e.g. admin1@example.com,admin2@example.com)
ADMIN_EMAIL=your_admin_email
QDRANT_URL=your_qdrant_instance_url
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=nosey_documents
RAG_EMBEDDING_MODEL=your_embedding_model_name
RAG_RERANKER_MODEL=your_reranker_model_name